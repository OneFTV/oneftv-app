{
  "name": "oneftv",
  "version": "1.0.0",
  "description": "Footvolley tournament management application",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "tester:preflight": "bash scripts/livefeed-preflight.sh",
    "tester:types": "npx tsc --noEmit",
    "tester:action": "bash scripts/tester-action.sh",
    "tester:full": "bash scripts/full-app-test.sh",
    "tester:run": "npm run tester:preflight || true && npm run tester:action",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "npx ts-node --compiler-options {\"module\":\"commonjs\"} prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5",
    "bcryptjs": "^2.4.3",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.563.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.5",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.10.3",
    "typescript": "^5",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/bcryptjs": "^2.4.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "prisma": "^5",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"commonjs\"} prisma/seed.ts"
  }
}
