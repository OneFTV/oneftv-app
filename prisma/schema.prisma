generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id           String      @id
  tournamentId String?
  userId       String?
  action       String      @db.VarChar(50)
  entityType   String      @db.VarChar(30)
  entityId     String?
  details      String?     @db.Text
  createdAt    DateTime    @default(now())
  Tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User         User?       @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([tournamentId])
  @@index([userId])
}

model Category {
  id                                                      String             @id
  tournamentId                                            String
  name                                                    String
  format                                                  String             @db.VarChar(30)
  gender                                                  String?            @db.VarChar(20)
  skillLevel                                              String?            @db.VarChar(20)
  maxTeams                                                Int                @default(16)
  pointsPerSet                                            Int                @default(18)
  numSets                                                 Int                @default(1)
  groupSize                                               Int                @default(4)
  proLeague                                               Boolean            @default(false)
  sortOrder                                               Int                @default(0)
  status                                                  String             @default("draft") @db.VarChar(20)
  qualifyTargetId                                         String?
  requiresReview                                          Boolean            @default(false)
  createdAt                                               DateTime           @default(now())
  updatedAt                                               DateTime
  bracketType                                             String?            @db.VarChar(30)
  divisionLabel                                           String?            @db.VarChar(10)
  seedingFromCategoryId                                   String?
  seedingSource                                           String?            @db.VarChar(30)
  Category_Category_qualifyTargetIdToCategory             Category?          @relation("Category_qualifyTargetIdToCategory", fields: [qualifyTargetId], references: [id])
  other_Category_Category_qualifyTargetIdToCategory       Category[]         @relation("Category_qualifyTargetIdToCategory")
  Category_Category_seedingFromCategoryIdToCategory       Category?          @relation("Category_seedingFromCategoryIdToCategory", fields: [seedingFromCategoryId], references: [id])
  other_Category_Category_seedingFromCategoryIdToCategory Category[]         @relation("Category_seedingFromCategoryIdToCategory")
  Tournament                                              Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  Game                                                    Game[]
  Group                                                   Group[]
  PricingLot                                              PricingLot[]
  Round                                                   Round[]
  ScheduleSlot                                            ScheduleSlot[]
  TeamRegistration                                        TeamRegistration[]
  TournamentPlayer                                        TournamentPlayer[]
  WaitlistEntry                                           WaitlistEntry[]

  @@index([qualifyTargetId])
  @@index([seedingFromCategoryId])
  @@index([tournamentId])
}

model CheckIn {
  id           String    @id
  userId       String
  categoryId   String?
  tournamentId String?
  qrCode       String    @unique
  checkedInAt  DateTime?
  status       String    @default("pending") @db.VarChar(20)
  createdAt    DateTime  @default(now())
  User         User      @relation(fields: [userId], references: [id])

  @@index([qrCode])
  @@index([userId])
}

model Game {
  id                                     String     @id
  tournamentId                           String
  groupId                                String?
  roundId                                String?
  courtNumber                            Int        @default(1)
  scheduledTime                          DateTime?
  player1HomeId                          String?
  player2HomeId                          String?
  player1AwayId                          String?
  player2AwayId                          String?
  scoreHome                              Int?
  scoreAway                              Int?
  set2Home                               Int?
  set2Away                               Int?
  set3Home                               Int?
  set3Away                               Int?
  status                                 String     @default("scheduled") @db.VarChar(20)
  winningSide                            String?    @db.VarChar(10)
  createdAt                              DateTime   @default(now())
  updatedAt                              DateTime
  categoryId                             String?
  bracketSide                            String?    @db.VarChar(20)
  loserNextGameId                        String?
  loserSlot                              String?    @db.VarChar(10)
  matchNumber                            Int?
  seedTarget                             String?    @db.VarChar(10)
  winnerNextGameId                       String?
  winnerSlot                             String?    @db.VarChar(10)
  Category                               Category?  @relation(fields: [categoryId], references: [id])
  Group                                  Group?     @relation(fields: [groupId], references: [id])
  Game_Game_loserNextGameIdToGame        Game?      @relation("Game_loserNextGameIdToGame", fields: [loserNextGameId], references: [id])
  other_Game_Game_loserNextGameIdToGame  Game[]     @relation("Game_loserNextGameIdToGame")
  User_Game_player1AwayIdToUser          User?      @relation("Game_player1AwayIdToUser", fields: [player1AwayId], references: [id])
  User_Game_player1HomeIdToUser          User?      @relation("Game_player1HomeIdToUser", fields: [player1HomeId], references: [id])
  User_Game_player2AwayIdToUser          User?      @relation("Game_player2AwayIdToUser", fields: [player2AwayId], references: [id])
  User_Game_player2HomeIdToUser          User?      @relation("Game_player2HomeIdToUser", fields: [player2HomeId], references: [id])
  Round                                  Round?     @relation(fields: [roundId], references: [id])
  Tournament                             Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  Game_Game_winnerNextGameIdToGame       Game?      @relation("Game_winnerNextGameIdToGame", fields: [winnerNextGameId], references: [id])
  other_Game_Game_winnerNextGameIdToGame Game[]     @relation("Game_winnerNextGameIdToGame")

  @@index([categoryId])
  @@index([groupId])
  @@index([loserNextGameId])
  @@index([matchNumber])
  @@index([player1AwayId])
  @@index([player1HomeId])
  @@index([player2AwayId])
  @@index([player2HomeId])
  @@index([roundId])
  @@index([status])
  @@index([tournamentId])
  @@index([winnerNextGameId])
}

model Group {
  id               String             @id
  name             String
  tournamentId     String
  categoryId       String?
  Game             Game[]
  Category         Category?          @relation(fields: [categoryId], references: [id])
  Tournament       Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  TournamentPlayer TournamentPlayer[]

  @@index([categoryId])
  @@index([tournamentId])
}

model LanguageDemand {
  id             String   @id
  browserLocale  String   @db.VarChar(20)
  normalizedLang String   @db.VarChar(10)
  pageUrl        String?  @db.VarChar(500)
  userAgent      String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([normalizedLang])
}

model Order {
  id                 String               @id
  userId             String
  tournamentId       String
  totalAmount        Float
  currency           String               @default("BRL") @db.VarChar(3)
  status             String               @default("pending") @db.VarChar(20)
  paymentMethod      String?              @db.VarChar(30)
  metadata           String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Tournament         Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User               User                 @relation(fields: [userId], references: [id])
  PaymentTransaction PaymentTransaction[]

  @@index([status])
  @@index([tournamentId])
  @@index([userId])
}

model PaymentTransaction {
  id              String   @id
  orderId         String
  externalId      String?
  provider        String?  @db.VarChar(30)
  amount          Float
  currency        String   @default("BRL") @db.VarChar(3)
  status          String   @db.VarChar(20)
  gatewayResponse String?  @db.Text
  createdAt       DateTime @default(now())
  Order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([orderId])
}

model PricingLot {
  id         String   @id
  categoryId String
  name       String
  price      Float
  currency   String   @default("BRL") @db.VarChar(3)
  maxEntries Int?
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model RefereeLink {
  id           String     @id
  tournamentId String
  courtNumber  Int
  token        String     @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, courtNumber])
  @@index([token])
}

model Round {
  id           String     @id
  name         String
  roundNumber  Int
  tournamentId String
  type         String     @db.VarChar(20)
  bestOf3      Boolean    @default(false)
  categoryId   String?
  bracketSide  String?    @db.VarChar(20)
  Game         Game[]
  Category     Category?  @relation(fields: [categoryId], references: [id])
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([tournamentId])
}

model ScheduleSlot {
  id           String     @id
  tournamentId String
  categoryId   String?
  courtNumber  Int
  dayNumber    Int        @default(1)
  startTime    DateTime
  endTime      DateTime
  label        String?
  createdAt    DateTime   @default(now())
  Category     Category?  @relation(fields: [categoryId], references: [id])
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([tournamentId])
}

model TeamRegistration {
  id                                    String             @id
  categoryId                            String
  player1Id                             String
  player2Id                             String
  teamName                              String?
  seed                                  Int?
  status                                String             @default("pending") @db.VarChar(20)
  createdAt                             DateTime           @default(now())
  updatedAt                             DateTime
  Category                              Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  User_TeamRegistration_player1IdToUser User               @relation("TeamRegistration_player1IdToUser", fields: [player1Id], references: [id])
  User_TeamRegistration_player2IdToUser User               @relation("TeamRegistration_player2IdToUser", fields: [player2Id], references: [id])
  TournamentPlayer                      TournamentPlayer[]

  @@unique([categoryId, player1Id, player2Id])
  @@index([categoryId])
  @@index([player1Id])
  @@index([player2Id])
}

model Tournament {
  id                     String             @id
  name                   String
  description            String?            @db.Text
  date                   DateTime
  endDate                DateTime?
  location               String
  city                   String?
  state                  String?
  country                String?
  format                 String?            @db.VarChar(30)
  status                 String             @default("draft") @db.VarChar(20)
  maxPlayers             Int?               @default(16)
  numCourts              Int                @default(1)
  numDays                Int                @default(1)
  hoursPerDay            Float              @default(8)
  avgGameMinutes         Int                @default(20)
  pointsPerSet           Int?               @default(18)
  numSets                Int                @default(1)
  groupSize              Int                @default(4)
  organizerId            String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime
  proLeague              Boolean            @default(false)
  allowMultiCategory     Boolean            @default(false)
  bannerUrl              String?            @db.Text
  contactEmail           String?
  contactPhone           String?
  refundPolicy           String?            @db.Text
  numReferees            Int                @default(1)
  stripeAccountId        String?
  venmoHandle            String?
  zelleInfo              String?
  primaryCourts          String?            @db.Text
  endTime                String?            @db.VarChar(5)
  startTime              String?            @db.VarChar(5)
  acceptedPaymentMethods String?            @db.Text
  registrationDeadline   DateTime?
  registrationFee        Float?
  AuditLog               AuditLog[]
  Category               Category[]
  Game                   Game[]
  Group                  Group[]
  Order                  Order[]
  RefereeLink            RefereeLink[]
  Round                  Round[]
  ScheduleSlot           ScheduleSlot[]
  User                   User               @relation(fields: [organizerId], references: [id])
  TournamentPlayer       TournamentPlayer[]

  @@index([date])
  @@index([format])
  @@index([organizerId])
  @@index([status])
}

model TournamentPlayer {
  id                 String            @id
  tournamentId       String
  userId             String
  seed               Int?
  groupId            String?
  points             Int               @default(0)
  wins               Int               @default(0)
  losses             Int               @default(0)
  pointDiff          Int               @default(0)
  status             String            @default("registered") @db.VarChar(20)
  categoryId         String?
  teamRegistrationId String?
  Category           Category?         @relation(fields: [categoryId], references: [id])
  Group              Group?            @relation(fields: [groupId], references: [id])
  TeamRegistration   TeamRegistration? @relation(fields: [teamRegistrationId], references: [id])
  Tournament         Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User               User              @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId, categoryId])
  @@index([categoryId])
  @@index([groupId])
  @@index([teamRegistrationId])
  @@index([tournamentId])
  @@index([userId])
}

model User {
  id                                                String             @id
  name                                              String
  email                                             String             @unique
  password                                          String
  role                                              String             @default("user") @db.VarChar(20)
  nationality                                       String?
  phone                                             String?
  street                                            String?
  number                                            String?
  complement                                        String?
  state                                             String?
  country                                           String?
  level                                             String?            @db.VarChar(20)
  avatar                                            String?            @db.Text
  createdAt                                         DateTime           @default(now())
  updatedAt                                         DateTime
  cpf                                               String?            @db.VarChar(14)
  dateOfBirth                                       DateTime?
  documentNumber                                    String?            @db.VarChar(30)
  documentType                                      String?            @db.VarChar(20)
  preferredLanguage                                 String?            @db.VarChar(10)
  AuditLog                                          AuditLog[]
  CheckIn                                           CheckIn[]
  Game_Game_player1AwayIdToUser                     Game[]             @relation("Game_player1AwayIdToUser")
  Game_Game_player1HomeIdToUser                     Game[]             @relation("Game_player1HomeIdToUser")
  Game_Game_player2AwayIdToUser                     Game[]             @relation("Game_player2AwayIdToUser")
  Game_Game_player2HomeIdToUser                     Game[]             @relation("Game_player2HomeIdToUser")
  Order                                             Order[]
  TeamRegistration_TeamRegistration_player1IdToUser TeamRegistration[] @relation("TeamRegistration_player1IdToUser")
  TeamRegistration_TeamRegistration_player2IdToUser TeamRegistration[] @relation("TeamRegistration_player2IdToUser")
  Tournament                                        Tournament[]
  TournamentPlayer                                  TournamentPlayer[]
}

model WaitlistEntry {
  id         String   @id
  categoryId String
  userId     String
  position   Int
  status     String   @default("waiting") @db.VarChar(20)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId])
  @@index([categoryId])
}
