generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id           String      @id @default(cuid())
  tournamentId String?
  userId       String?
  action       String      @db.VarChar(50)
  entityType   String      @db.VarChar(30)
  entityId     String?
  details      String?     @db.Text
  createdAt    DateTime    @default(now())
  Tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User         User?       @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([tournamentId])
  @@index([userId])
}

model Category {
  id                                                      String             @id @default(cuid())
  tournamentId                                            String
  name                                                    String
  format                                                  String             @db.VarChar(30)
  gender                                                  String?            @db.VarChar(20)
  skillLevel                                              String?            @db.VarChar(20)
  maxTeams                                                Int                @default(16)
  pointsPerSet                                            Int                @default(18)
  numSets                                                 Int                @default(1)
  groupSize                                               Int                @default(4)
  proLeague                                               Boolean            @default(false)
  sortOrder                                               Int                @default(0)
  status                                                  String             @default("draft") @db.VarChar(20)
  qualifyTargetId                                         String?
  requiresReview                                          Boolean            @default(false)
  createdAt                                               DateTime           @default(now())
  updatedAt                                               DateTime @updatedAt
  bracketType                                             String?            @db.VarChar(30)
  divisionLabel                                           String?            @db.VarChar(10)
  seedingFromCategoryId                                   String?
  seedingSource                                           String?            @db.VarChar(30)
  scheduledDay                                            Int?               @default(1)
  dayStartTime                                            String?            @db.VarChar(5)
  dayEndTime                                              String?            @db.VarChar(5)
  Category_Category_qualifyTargetIdToCategory             Category?          @relation("Category_qualifyTargetIdToCategory", fields: [qualifyTargetId], references: [id])
  other_Category_Category_qualifyTargetIdToCategory       Category[]         @relation("Category_qualifyTargetIdToCategory")
  Category_Category_seedingFromCategoryIdToCategory       Category?          @relation("Category_seedingFromCategoryIdToCategory", fields: [seedingFromCategoryId], references: [id])
  other_Category_Category_seedingFromCategoryIdToCategory Category[]         @relation("Category_seedingFromCategoryIdToCategory")
  Tournament                                              Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  Game                                                    Game[]
  Group                                                   Group[]
  PricingLot                                              PricingLot[]
  Round                                                   Round[]
  ScheduleSlot                                            ScheduleSlot[]
  TeamRegistration                                        TeamRegistration[]
  TournamentPlayer                                        TournamentPlayer[]
  WaitlistEntry                                           WaitlistEntry[]

  @@index([qualifyTargetId])
  @@index([seedingFromCategoryId])
  @@index([tournamentId])
}

model CheckIn {
  id           String    @id @default(cuid())
  userId       String
  categoryId   String?
  tournamentId String?
  qrCode       String    @unique
  checkedInAt  DateTime?
  status       String    @default("pending") @db.VarChar(20)
  createdAt    DateTime  @default(now())
  User         User      @relation(fields: [userId], references: [id])

  @@index([qrCode])
  @@index([userId])
}

model Game {
  id                                     String     @id @default(cuid())
  tournamentId                           String
  groupId                                String?
  roundId                                String?
  courtNumber                            Int        @default(1)
  scheduledTime                          DateTime?
  player1HomeId                          String?
  player2HomeId                          String?
  player1AwayId                          String?
  player2AwayId                          String?
  scoreHome                              Int?
  scoreAway                              Int?
  set2Home                               Int?
  set2Away                               Int?
  set3Home                               Int?
  set3Away                               Int?
  status                                 String     @default("scheduled") @db.VarChar(20)
  winningSide                            String?    @db.VarChar(10)
  createdAt                              DateTime   @default(now())
  updatedAt                              DateTime @updatedAt
  categoryId                             String?
  bracketSide                            String?    @db.VarChar(20)
  loserNextGameId                        String?
  loserSlot                              String?    @db.VarChar(10)
  matchNumber                            Int?
  seedTarget                             String?    @db.VarChar(10)
  displayMatchNumber                     Int?
  winnerNextGameId                       String?
  winnerSlot                             String?    @db.VarChar(10)
  Category                               Category?  @relation(fields: [categoryId], references: [id])
  Group                                  Group?     @relation(fields: [groupId], references: [id])
  Game_Game_loserNextGameIdToGame        Game?      @relation("Game_loserNextGameIdToGame", fields: [loserNextGameId], references: [id])
  other_Game_Game_loserNextGameIdToGame  Game[]     @relation("Game_loserNextGameIdToGame")
  User_Game_player1AwayIdToUser          User?      @relation("Game_player1AwayIdToUser", fields: [player1AwayId], references: [id])
  User_Game_player1HomeIdToUser          User?      @relation("Game_player1HomeIdToUser", fields: [player1HomeId], references: [id])
  User_Game_player2AwayIdToUser          User?      @relation("Game_player2AwayIdToUser", fields: [player2AwayId], references: [id])
  User_Game_player2HomeIdToUser          User?      @relation("Game_player2HomeIdToUser", fields: [player2HomeId], references: [id])
  Round                                  Round?     @relation(fields: [roundId], references: [id])
  Tournament                             Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  Game_Game_winnerNextGameIdToGame       Game?      @relation("Game_winnerNextGameIdToGame", fields: [winnerNextGameId], references: [id])
  other_Game_Game_winnerNextGameIdToGame Game[]     @relation("Game_winnerNextGameIdToGame")

  @@index([categoryId])
  @@index([groupId])
  @@index([loserNextGameId])
  @@index([matchNumber])
  @@index([player1AwayId])
  @@index([player1HomeId])
  @@index([player2AwayId])
  @@index([player2HomeId])
  @@index([roundId])
  @@index([status])
  @@index([tournamentId])
  @@index([winnerNextGameId])
}

model Group {
  id               String             @id @default(cuid())
  name             String
  tournamentId     String
  categoryId       String?
  Game             Game[]
  Category         Category?          @relation(fields: [categoryId], references: [id])
  Tournament       Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  TournamentPlayer TournamentPlayer[]

  @@index([categoryId])
  @@index([tournamentId])
}

model LanguageDemand {
  id             String   @id @default(cuid())
  browserLocale  String   @db.VarChar(20)
  normalizedLang String   @db.VarChar(10)
  pageUrl        String?  @db.VarChar(500)
  userAgent      String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([normalizedLang])
}

model Order {
  id                 String               @id @default(cuid())
  userId             String
  tournamentId       String
  totalAmount        Float
  currency           String               @default("BRL") @db.VarChar(3)
  status             String               @default("pending") @db.VarChar(20)
  paymentMethod      String?              @db.VarChar(30)
  metadata           String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime @updatedAt
  Tournament         Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User               User                 @relation(fields: [userId], references: [id])
  PaymentTransaction PaymentTransaction[]

  @@index([status])
  @@index([tournamentId])
  @@index([userId])
}

model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String
  externalId      String?
  provider        String?  @db.VarChar(30)
  amount          Float
  currency        String   @default("BRL") @db.VarChar(3)
  status          String   @db.VarChar(20)
  gatewayResponse String?  @db.Text
  createdAt       DateTime @default(now())
  Order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([orderId])
}

model PricingLot {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  price      Float
  currency   String   @default("BRL") @db.VarChar(3)
  maxEntries Int?
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model RefereeLink {
  id           String     @id @default(cuid())
  tournamentId String
  courtNumber  Int
  token        String     @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime @updatedAt
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, courtNumber])
  @@index([token])
}

model Round {
  id           String     @id @default(cuid())
  name         String
  roundNumber  Int
  tournamentId String
  type         String     @db.VarChar(20)
  bestOf3      Boolean    @default(false)
  categoryId   String?
  bracketSide  String?    @db.VarChar(20)
  Game         Game[]
  Category     Category?  @relation(fields: [categoryId], references: [id])
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([tournamentId])
}

model ScheduleSlot {
  id           String     @id @default(cuid())
  tournamentId String
  categoryId   String?
  courtNumber  Int
  dayNumber    Int        @default(1)
  startTime    DateTime
  endTime      DateTime
  label        String?
  createdAt    DateTime   @default(now())
  Category     Category?  @relation(fields: [categoryId], references: [id])
  Tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([tournamentId])
}

model TeamRegistration {
  id                                    String             @id @default(cuid())
  categoryId                            String
  player1Id                             String
  player2Id                             String
  teamName                              String?
  seed                                  Int?
  status                                String             @default("pending") @db.VarChar(20)
  createdAt                             DateTime           @default(now())
  updatedAt                             DateTime @updatedAt
  Category                              Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  User_TeamRegistration_player1IdToUser User               @relation("TeamRegistration_player1IdToUser", fields: [player1Id], references: [id])
  User_TeamRegistration_player2IdToUser User               @relation("TeamRegistration_player2IdToUser", fields: [player2Id], references: [id])
  TournamentPlayer                      TournamentPlayer[]

  @@unique([categoryId, player1Id, player2Id])
  @@index([categoryId])
  @@index([player1Id])
  @@index([player2Id])
}

model Tournament {
  id                     String             @id @default(cuid())
  name                   String
  description            String?            @db.Text
  date                   DateTime
  endDate                DateTime?
  location               String
  city                   String?
  state                  String?
  country                String?
  format                 String?            @db.VarChar(30)
  status                 String             @default("draft") @db.VarChar(20)
  maxPlayers             Int?               @default(16)
  numCourts              Int                @default(1)
  numDays                Int                @default(1)
  hoursPerDay            Float              @default(8)
  avgGameMinutes         Int                @default(20)
  pointsPerSet           Int?               @default(18)
  numSets                Int                @default(1)
  groupSize              Int                @default(4)
  organizerId            String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime @updatedAt
  proLeague              Boolean            @default(false)
  allowMultiCategory     Boolean            @default(false)
  bannerUrl              String?            @db.Text
  contactEmail           String?
  contactPhone           String?
  refundPolicy           String?            @db.Text
  numReferees            Int                @default(1)
  stripeAccountId        String?
  venmoHandle            String?
  zelleInfo              String?
  primaryCourts          String?            @db.Text
  openDivisionCount      Int                @default(3)
  endTime                String?            @db.VarChar(5)
  startTime              String?            @db.VarChar(5)
  acceptedPaymentMethods String?            @db.Text
  registrationDeadline   DateTime?
  registrationFee        Float?
  AuditLog               AuditLog[]
  Category               Category[]
  Game                   Game[]
  Group                  Group[]
  Order                  Order[]
  RefereeLink            RefereeLink[]
  Round                  Round[]
  ScheduleSlot           ScheduleSlot[]
  User                   User               @relation(fields: [organizerId], references: [id])
  TournamentPlayer       TournamentPlayer[]

  @@index([date])
  @@index([format])
  @@index([organizerId])
  @@index([status])
}

model TournamentPlayer {
  id                 String            @id @default(cuid())
  tournamentId       String
  userId             String
  seed               Int?
  groupId            String?
  points             Int               @default(0)
  wins               Int               @default(0)
  losses             Int               @default(0)
  pointDiff          Int               @default(0)
  status             String            @default("registered") @db.VarChar(20)
  categoryId         String?
  teamRegistrationId String?
  Category           Category?         @relation(fields: [categoryId], references: [id])
  Group              Group?            @relation(fields: [groupId], references: [id])
  TeamRegistration   TeamRegistration? @relation(fields: [teamRegistrationId], references: [id])
  Tournament         Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  User               User              @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId, categoryId])
  @@index([categoryId])
  @@index([groupId])
  @@index([teamRegistrationId])
  @@index([tournamentId])
  @@index([userId])
}

model User {
  id                                                String             @id @default(cuid())
  name                                              String
  email                                             String             @unique
  password                                          String
  role                                              String             @default("user") @db.VarChar(20)
  nationality                                       String?
  phone                                             String?
  street                                            String?
  number                                            String?
  complement                                        String?
  state                                             String?
  country                                           String?
  level                                             String?            @db.VarChar(20)
  avatar                                            String?            @db.Text
  createdAt                                         DateTime           @default(now())
  updatedAt                                         DateTime @updatedAt
  cpf                                               String?            @db.VarChar(14)
  dateOfBirth                                       DateTime?
  documentNumber                                    String?            @db.VarChar(30)
  documentType                                      String?            @db.VarChar(20)
  preferredLanguage                                 String?            @db.VarChar(10)
  coachProfile                                      CoachProfile?
  studentProfile                                    StudentProfile?
  AuditLog                                          AuditLog[]
  CheckIn                                           CheckIn[]
  Game_Game_player1AwayIdToUser                     Game[]             @relation("Game_player1AwayIdToUser")
  Game_Game_player1HomeIdToUser                     Game[]             @relation("Game_player1HomeIdToUser")
  Game_Game_player2AwayIdToUser                     Game[]             @relation("Game_player2AwayIdToUser")
  Game_Game_player2HomeIdToUser                     Game[]             @relation("Game_player2HomeIdToUser")
  Order                                             Order[]
  TeamRegistration_TeamRegistration_player1IdToUser TeamRegistration[] @relation("TeamRegistration_player1IdToUser")
  TeamRegistration_TeamRegistration_player2IdToUser TeamRegistration[] @relation("TeamRegistration_player2IdToUser")
  Tournament                                        Tournament[]
  TournamentPlayer                                  TournamentPlayer[]
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  categoryId String
  userId     String
  position   Int
  status     String   @default("waiting") @db.VarChar(20)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId])
  @@index([categoryId])
}

model AnalyticsPageview {
  id        String   @id @default(cuid())
  path      String
  vid       String
  country   String   @default("unknown")
  device    String   @default("desktop")
  referrer  String   @default("direct")
  isBot     Boolean  @default(false)
  date      String
  ts        BigInt
  createdAt DateTime @default(now())

  @@index([ts])
  @@index([date])
  @@index([vid])
}

model AnalyticsEvent {
  id    String @id @default(cuid())
  event String
  data  String @default("{}")
  vid   String @default("anon")
  date  String
  ts    BigInt

  @@index([ts])
}

model AnalyticsSession {
  id       String @id @default(cuid())
  vid      String
  duration Int
  date     String
  ts       BigInt

  @@index([ts])
}

// ============================================
// AULAS MODULE
// ============================================

model CoachProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  bio            String?  @db.Text
  experience     String?  @db.Text
  certifications String?  @db.Text
  hourlyRate     Decimal? @db.Decimal(10, 2)
  currency       String   @default("USD")
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  city           String?
  state          String?
  country        String?
  locationName   String?
  maxGroupSize   Int      @default(4)
  isActive       Boolean  @default(true)
  isVerified     Boolean  @default(false)
  photos         String?  @db.Text
  coverPhoto     String?
  classes        Class[]
  students       CoachStudent[]
  evaluations    StudentEvaluation[]
  packages       ClassPackage[]
  reviews        CoachReview[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([latitude, longitude])
  @@index([city, state, country])
  @@index([isActive])
}

model StudentProfile {
  id               String            @id @default(cuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id])
  startedPlaying   DateTime?
  dominantFoot     String?
  position         String?
  currentLevel     String?
  totalClasses     Int               @default(0)
  totalCoaches     Int               @default(0)
  coaches          CoachStudent[]
  evaluations      StudentEvaluation[]
  classAttendances ClassAttendance[]
  payments         AulaPayment[]
  reviews          CoachReview[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model CoachStudent {
  id        String         @id @default(cuid())
  coachId   String
  coach     CoachProfile   @relation(fields: [coachId], references: [id])
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])
  status    String         @default("active")
  startDate DateTime       @default(now())
  endDate   DateTime?
  notes     String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([coachId, studentId])
  @@index([coachId])
  @@index([studentId])
}

model Class {
  id             String            @id @default(cuid())
  coachId        String
  coach          CoachProfile      @relation(fields: [coachId], references: [id])
  title          String
  description    String?           @db.Text
  type           String
  maxStudents    Int               @default(1)
  scheduledAt    DateTime
  duration       Int
  timezone       String            @default("America/New_York")
  locationName   String?
  latitude       Decimal?          @db.Decimal(10, 7)
  longitude      Decimal?          @db.Decimal(10, 7)
  price          Decimal?          @db.Decimal(10, 2)
  currency       String            @default("USD")
  status         String            @default("scheduled")
  notes          String?           @db.Text
  isRecurring    Boolean           @default(false)
  recurrenceRule String?
  attendances    ClassAttendance[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([coachId])
  @@index([scheduledAt])
  @@index([status])
}

model ClassAttendance {
  id          String          @id @default(cuid())
  classId     String
  class       Class           @relation(fields: [classId], references: [id])
  studentId   String
  student     StudentProfile  @relation(fields: [studentId], references: [id])
  status      String          @default("registered")
  checkedInAt DateTime?
  createdAt   DateTime        @default(now())

  @@unique([classId, studentId])
  @@index([studentId])
}

model StudentEvaluation {
  id              String         @id @default(cuid())
  coachId         String
  coach           CoachProfile   @relation(fields: [coachId], references: [id])
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id])
  evaluatedAt     DateTime       @default(now())
  overallLevel    String
  overallNotes    String?        @db.Text
  // Ataque (Offense)
  shark           Int?  // Tubarão — ataque com a sola do pé por cima da rede
  pingo           Int?  // Ataque curto/sutil que cai logo após a rede
  lobby           Int?  // Ataque alto ao fundo da quadra, por cima do adversário
  paralela        Int?  // Ataque reto que segue a linha lateral da quadra
  meioFundo       Int?  // Ataque ao centro, entre a rede e a linha de fundo
  diagonalCurta   Int?  // Ataque cruzado curto ao lado oposto
  diagonalLonga   Int?  // Ataque cruzado longo ao lado oposto
  cabeceio        Int?  // Finalização com a cabeça
  chapa           Int?  // Ataque de precisão com a parte interna do pé
  peitoDePe       Int?  // Ataque de potência com o dorso do pé

  // Levantamento (Setting)
  chestSet        Int?  // Levantada de peito
  headSet         Int?  // Levantada de cabeça
  shoulderSet     Int?  // Levantada de ombro
  footSet         Int?  // Levantada de pé

  // Defesa e Recepção (Defense & Reception)
  defesaLobby     Int?  // Recuperação de bolas altas no fundo (giro + leitura)
  defesaPingo     Int?  // Cobertura de bolas curtas perto da rede
  defesaParalela  Int?  // Posicionamento para segurar ataque reto na linha
  defesaMeioFundo Int?  // Cobertura da zona central da quadra
  defesaDiagonal  Int?  // Cobertura de ataques cruzados
  recepcao        Int?  // Primeiro toque para controlar saque ou ataque

  // Saque (Serve)
  saque           Int?  // Qualidade e variedade do saque

  // Tático / Físico
  posicionamento  Int?  // Posicionamento em quadra e leitura de jogo
  bloqueio        Int?  // Bloqueio na rede — geralmente via shark, raramente cabeça
  weaknesses      String?        @db.Text
  strengths       String?        @db.Text
  recommendations String?        @db.Text
  createdAt       DateTime       @default(now())

  @@index([studentId])
  @@index([coachId])
  @@index([evaluatedAt])
}

model ClassPackage {
  id          String            @id @default(cuid())
  coachId     String
  coach       CoachProfile      @relation(fields: [coachId], references: [id])
  name        String
  description String?           @db.Text
  type        String
  classCount  Int?
  price       Decimal           @db.Decimal(10, 2)
  currency    String            @default("USD")
  validDays   Int?
  isActive    Boolean           @default(true)
  purchases   PackagePurchase[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([coachId])
}

model PackagePurchase {
  id          String         @id @default(cuid())
  packageId   String
  package     ClassPackage   @relation(fields: [packageId], references: [id])
  studentId   String
  classesUsed Int            @default(0)
  status      String         @default("active")
  purchasedAt DateTime       @default(now())
  expiresAt   DateTime?
  payments    AulaPayment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([studentId])
  @@index([packageId])
}

model AulaPayment {
  id         String           @id @default(cuid())
  studentId  String
  student    StudentProfile   @relation(fields: [studentId], references: [id])
  amount     Decimal          @db.Decimal(10, 2)
  currency   String           @default("USD")
  method     String
  status     String           @default("confirmed")
  type       String
  classId    String?
  purchaseId String?
  purchase   PackagePurchase? @relation(fields: [purchaseId], references: [id])
  notes      String?
  paidAt     DateTime         @default(now())
  createdAt  DateTime         @default(now())

  @@index([studentId])
  @@index([paidAt])
}

model CoachReview {
  id        String         @id @default(cuid())
  coachId   String
  coach     CoachProfile   @relation(fields: [coachId], references: [id])
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])
  rating    Int
  comment   String?        @db.Text
  isPublic  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([coachId, studentId])
  @@index([coachId])
}
